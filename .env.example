DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...

# Redis (Upstash - optional but recommended for production)
# Get these from https://upstash.com/ after creating a database
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Cron Secret (for protecting cron endpoints)
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# eSewa Payment Gateway (Nepal)
# For development, test credentials are pre-filled below
# For production, contact eSewa for live credentials
ESEWA_PRODUCT_CODE=INTENT
ESEWA_MERCHANT_ID=EPAYTEST
ESEWA_ACCESS_KEY=LB0REg8HUSw3MTYrI1s6JTE8Kyc6JyAqJiA3MQ==

# Khalti Payment Gateway (Nepal)
# Get your keys from https://test-admin.khalti.com (sandbox) or https://admin.khalti.com (production)
# Test Secret Key for sandbox environment (default)
KHALTI_SECRET_KEY=05bf95cc57244045b8df5fad06748dab
# For production, set your live secret key:
# KHALTI_SECRET_KEY=your_live_secret_key_here

# App
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
